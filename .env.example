# SumUp — use either a personal access token (simplest)
# or OAuth client credentials (client_id + client_secret).
# Get these from https://developer.sumup.com

SUMUP_ACCESS_TOKEN=your_personal_access_token
# SUMUP_CLIENT_ID=your_client_id
# SUMUP_CLIENT_SECRET=your_client_secret

# Stripe secret key — get this from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
